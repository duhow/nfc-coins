<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Left panel: card info, balance, status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="16dp">

            <!-- Card ID -->
            <TextView
                android:id="@+id/tvCardId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_card_detected"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <!-- Large balance number (EditText to allow custom deduction entry) -->
            <EditText
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/balance_initial"
                android:textSize="72sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"
                android:background="@null"
                android:inputType="none"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/coins_label"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <!-- Before → After balance row (shown after deduction or add) -->
            <LinearLayout
                android:id="@+id/layoutBeforeAfter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvBalanceBefore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" → "
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tvBalanceAfter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Saldo actual (visible solo en caso de saldo insuficiente con cantidad personalizada) -->
            <TextView
                android:id="@+id/tvActualBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Status message -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/waiting_card"
                android:textSize="14sp"
                android:gravity="center" />

            <!-- Hidden EditText used as keyboard target for custom deduction entry.
                 Height is 1dp (non-zero) so the IMM can show the keyboard; alpha=0 keeps it invisible. -->
            <EditText
                android:id="@+id/etHiddenInput"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:inputType="number"
                android:background="@null"
                android:alpha="0"
                android:cursorVisible="false"
                android:importantForAccessibility="no" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="?android:attr/listDivider"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Right panel: toggle coin deduction buttons -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="16dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:singleSelection="true"
                app:selectionRequired="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeduct1"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:text="@string/deduct_1_short"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeduct2"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:text="@string/deduct_2_short"
                    android:textSize="26sp"
                    android:textStyle="bold" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
