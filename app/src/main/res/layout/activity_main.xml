<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Card ID -->
        <TextView
            android:id="@+id/tvCardId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_card_detected"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Large balance number (EditText to allow custom deduction entry) -->
        <EditText
            android:id="@+id/tvBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/balance_initial"
            android:textSize="72sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:background="@null"
            android:inputType="none"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/coins_label"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <!-- Before → After balance row (shown after deduction or add) -->
        <LinearLayout
            android:id="@+id/layoutBeforeAfter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvBalanceBefore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" → "
                android:textSize="28sp" />

            <TextView
                android:id="@+id/tvBalanceAfter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Saldo actual (visible solo en caso de saldo insuficiente con cantidad personalizada) -->
        <TextView
            android:id="@+id/tvActualBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Status message -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/waiting_card"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Hidden EditText used as keyboard target for custom deduction entry.
             Height is 1dp (non-zero) so the IMM can show the keyboard; alpha=0 keeps it invisible. -->
        <net.duhowpi.nfccoins.BackspaceEditText
            android:id="@+id/etHiddenInput"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:inputType="number"
            android:background="@null"
            android:alpha="0"
            android:cursorVisible="false"
            android:importantForAccessibility="no" />

        <!-- Toggle coin deduction buttons in a row -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeduct1"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="@string/deduct_1_short"
                android:textSize="26sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeduct2"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="@string/deduct_2_short"
                android:textSize="26sp"
                android:textStyle="bold" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Transaction history (shown after reading a card) -->
        <LinearLayout
            android:id="@+id/layoutTransactionHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tx_history_label"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:alpha="0.6"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTx0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTx1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTx2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTx3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTxDebug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:alpha="0.7"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
