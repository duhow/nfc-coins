<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Card ID -->
    <TextView
        android:id="@+id/tvCardId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_card_detected"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <!-- Balance -->
    <TextView
        android:id="@+id/tvBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/balance_initial"
        android:textSize="48sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/coins_label"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/waiting_card"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <!-- Deduct buttons -->
    <Button
        android:id="@+id/btnDeduct1"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/deduct_1"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"
        android:enabled="false" />

    <Button
        android:id="@+id/btnDeduct2"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="@string/deduct_2"
        android:textSize="18sp"
        android:enabled="false" />

</LinearLayout>
