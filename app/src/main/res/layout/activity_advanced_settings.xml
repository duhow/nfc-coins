<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Sector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_target_sector"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setting_target_sector_hint"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Static key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_static_key"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaticKey"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStaticKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="monospace" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Eye button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleKeyVisibility"
                style="?attr/materialIconButtonStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="@string/btn_show_key"
                app:icon="@drawable/ic_eye"
                app:iconPadding="0dp"
                app:iconGravity="textStart" />

            <!-- Generate random button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateKey"
                style="?attr/materialIconButtonStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="@string/btn_generate_key"
                app:icon="@drawable/ic_refresh"
                app:iconPadding="0dp"
                app:iconGravity="textStart" />

        </LinearLayout>

        <!-- Dynamic key checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbDynamicKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_dynamic_key"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Flash background checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbFlashEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_flash_enabled"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Verify card integrity checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbVerifyIntegrity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_verify_integrity"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Debug mode checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbDebugEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_debug_mode"
            android:checked="false"
            android:layout_marginBottom="8dp" />

        <!-- Keep screen on checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbKeepScreenOn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_keep_screen_on"
            android:checked="false"
            android:layout_marginBottom="8dp" />

        <!-- Sound enabled checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbSoundEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_sound_enabled"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Vibration enabled checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbVibrationEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_vibration_enabled"
            android:checked="false"
            android:layout_marginBottom="8dp" />

        <!-- Theme color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_theme_color"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/colorSelectorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_settings" />

    </LinearLayout>

</ScrollView>
