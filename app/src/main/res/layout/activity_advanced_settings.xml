<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:importantForAutofill="noExcludeDescendants">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_language"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginBottom="24dp">

            <AutoCompleteTextView
                android:id="@+id/actvLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenLanguageSettings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setting_language_change_system"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Sector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_target_sector"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setting_target_sector_hint"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Static key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_static_key"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilStaticKey"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStaticKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="monospace" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Eye button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleKeyVisibility"
                style="?attr/materialIconButtonStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="@string/btn_show_key"
                app:icon="@drawable/ic_eye"
                app:iconPadding="0dp"
                app:iconGravity="textStart" />

            <!-- Generate random button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateKey"
                style="?attr/materialIconButtonStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:contentDescription="@string/btn_generate_key"
                app:icon="@drawable/ic_refresh"
                app:iconPadding="0dp"
                app:iconGravity="textStart" />

        </LinearLayout>

        <!-- Toggle settings section header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_options"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Dynamic key row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_key"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swDynamicKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_dynamic_key"
                android:checked="true" />
        </LinearLayout>

        <!-- Flash background row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_palette"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swFlashEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_flash_enabled"
                android:checked="true" />
        </LinearLayout>

        <!-- Verify card integrity row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_verified"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swVerifyIntegrity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_verify_integrity"
                android:checked="true" />
        </LinearLayout>

        <!-- Seller mode row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_store"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swSellerMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_seller_mode"
                android:checked="false" />
        </LinearLayout>

        <!-- Debug mode row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_bug_report"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swDebugEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_debug_mode"
                android:checked="false" />
        </LinearLayout>

        <!-- Keep screen on row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_screen"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swKeepScreenOn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_keep_screen_on"
                android:checked="false" />
        </LinearLayout>

        <!-- Sound enabled row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_volume"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swSoundEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_sound_enabled"
                android:checked="true" />
        </LinearLayout>

        <!-- Vibration enabled row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_vibrate"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swVibrationEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_vibration_enabled"
                android:checked="false" />
        </LinearLayout>

        <!-- Decimal mode row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_decimal"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swDecimalMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_decimal_mode"
                android:checked="false" />
        </LinearLayout>

        <!-- Distributed POS row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_share"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swDistributedPos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_distributed_pos"
                android:checked="false" />
        </LinearLayout>

        <!-- Broadcast events row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_broadcast"
                app:tint="?attr/colorControlNormal" />
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swBroadcastEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setting_broadcast_enabled"
                android:checked="false" />
        </LinearLayout>

        <!-- Legal adult age -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_legal_age"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLegalAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setting_legal_age_hint"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLegalAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Theme color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_theme_color"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/colorSelectorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_settings" />

    </LinearLayout>

</ScrollView>
